Options -Indexes

# Serve index.php before index.html
DirectoryIndex index.php index.html

# PHP error logging
php_flag display_errors Off
php_flag log_errors On

# Charset padrão
AddDefaultCharset UTF-8

# ── URLs amigáveis ────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Não reescrever arquivos ou diretórios que existem
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Páginas principais (pasta site/paginas/)
    RewriteRule ^run/academy/?$     site/paginas/run-academy.php    [L]
    RewriteRule ^run/projects/?$    site/paginas/run-projects.php   [L]
    RewriteRule ^run/cowork/?$      site/paginas/run-cowork.php     [L]
    RewriteRule ^run/consulting/?$  site/paginas/run-consulting.php [L]
    RewriteRule ^run/?$             site/paginas/run.php            [L]
    RewriteRule ^blog/?$           site/paginas/blog.php           [L]
    RewriteRule ^guideline/?$      site/paginas/guideline.php      [L]
    RewriteRule ^gerar-imagem/?$   site/paginas/gerar-imagem.php   [L]

    # Posts do blog: /blog/meu-post → post.php?slug=meu-post
    RewriteRule ^blog/([a-z0-9\-]+)/?$ site/paginas/post.php?slug=$1 [L,QSA]
</IfModule>

# ── Segurança ─────────────────────────────────────────────────────────────────
<FilesMatch "^config\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
